# ═══════════════════════════════════════════════════════════════════════════════
#  PirateClick by dopinity — .env configuration
#  Copy this file to .env and fill in all values.
#  NEVER commit .env to git!
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production
LOG_LEVEL=info

# ─── MongoDB Atlas ────────────────────────────────────────────────────────────
# Get from: Atlas → Cluster → Connect → Drivers → Standard connection string
# Replace USER, PASSWORD, CLUSTER with your actual values.
# Example (standard/direct format — more reliable than SRV on Windows):
#   mongodb://USER:PASSWORD@ac-xxx-shard-00-00.mongodb.net:27017,.../?ssl=true&replicaSet=...&authSource=admin
MONGO_URI=mongodb://USER:PASSWORD@ac-xxx.mongodb.net:27017/pirateclick?ssl=true&replicaSet=...&authSource=admin

# ─── Redis (Upstash — recommended) ───────────────────────────────────────────
# Get from: Upstash Console → Database → Details → "Redis (TCP)" tab
# Format: rediss://default:PASSWORD@HOST:6379
REDIS_URL=rediss://default:YOUR_UPSTASH_PASSWORD@your-hostname.upstash.io:6379

# ─── WhatsApp ─────────────────────────────────────────────────────────────────
WA_SESSION_PATH=./sessions

# ─── NLP ─────────────────────────────────────────────────────────────────────
NLP_CONFIDENCE_THRESHOLD=0.65
EMBEDDING_MODEL=minilm

# ─── Dispatch ────────────────────────────────────────────────────────────────
DRIVER_TTL_SECONDS=600
CLAIM_DELAY_MIN_MS=100
CLAIM_DELAY_MAX_MS=2000
DRIVER_RESPONSE_TIMEOUT_MS=60000
MAX_DRIVER_RETRIES=3
RADIUS_EXPANSION_STEPS=2

# ─── Email (Support Form — optional) ─────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SUPPORT_EMAIL=support@yourdomain.com

# ─── Metrics ─────────────────────────────────────────────────────────────────
METRICS_FLUSH_INTERVAL_MS=30000

# ─── Learning ────────────────────────────────────────────────────────────────
LEARNING_CYCLE_INTERVAL_MS=1800000

# ════════════════════════════════════════════════════════════════════════════
#  SaaS LICENSE SYSTEM — KEEP THESE SECRET
# ════════════════════════════════════════════════════════════════════════════

# Generate with: node scripts/generateSecrets.js
JWT_SECRET=REPLACE_WITH_64_CHAR_HEX
JWT_EXPIRES_IN=7d

# Admin API key — used to access /api/admin/* (REST only, no UI)
ADMIN_API_KEY=REPLACE_WITH_32_CHAR_HEX

# WhatsApp number to receive "new user registered" alerts
# International format, NO + prefix. Example: 905321234567
ADMIN_WA_NUMBER=905XXXXXXXXX
